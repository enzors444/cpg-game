// Começa 100% transparente
image_alpha = 0; 

// 1 significa que está aparecendo (Fade In), -1 significa que está sumindo (Fade Out)
estado_fade = 1; 

// Controla a velocidade que ele aparece e some. 
// Aumente para ser mais rápido (ex: 0.1) ou diminua para ser mais lento (ex: 0.02)
velocidade_fade = 0.05; 

// Opcional: faz o efeito subir bem devagarzinho enquanto aparece (dá um charme extra!)
y_speed = -0.5;